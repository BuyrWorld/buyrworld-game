#!/usr/bin/env sh
# Pre-push: run the fast Vitest suite (data invariants + logic). Blocks the push
# if it fails. The slower Playwright first-hour E2E gate runs in CI on push/PR
# (see .github/workflows/gate.yml), so it's not repeated here.
#
# Skip a single push with:  git push --no-verify
# Skip via env:             BUYR_SKIP_GATE=1 git push
if [ "$BUYR_SKIP_GATE" = "1" ]; then
  echo "↷ pre-push tests skipped (BUYR_SKIP_GATE=1)"
  exit 0
fi

# Node/npm are usually on PATH in a normal shell; fall back to the default
# Windows install dir if not (matches this repo's setup).
if ! command -v npm >/dev/null 2>&1; then
  export PATH="/c/Program Files/nodejs:$PATH"
fi
if ! command -v npm >/dev/null 2>&1; then
  echo "✖ pre-push: npm not found on PATH — cannot run tests." >&2
  echo "  Install Node, or push with:  git push --no-verify" >&2
  exit 1
fi

echo "▶ pre-push: npm test  (Vitest — the Playwright E2E gate runs in CI)…"
npm test
status=$?
if [ $status -ne 0 ]; then
  echo "✖ unit tests FAILED — push blocked. Fix them, or override with:  git push --no-verify" >&2
fi
exit $status
