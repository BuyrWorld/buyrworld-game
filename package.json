{
  "name": "buyrworld-game",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install chromium",
    "gate": "vitest run && playwright test",
    "prepare": "node scripts/install-hooks.mjs",
    "check:data": "node scripts/check-data.js",
    "gen:icons": "node scripts/gen-icons.mjs",
    "electron": "vite build && electron .",
    "electron:dev": "cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "dist:desktop": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:steam": "vite build && electron-builder --win --dir"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
